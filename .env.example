# ===== CONFIGURAÇÃO DO MERCADO PAGO =====

# Suas credenciais do Mercado Pago
# Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
MERCADO_PAGO_TOKEN=seu_access_token_aqui

# URL base para webhooks (para produção)
# BASE_URL=https://seu-dominio.ngrok.io

# Porta do servidor
PORT=3000

# ===== COMO CONFIGURAR =====
# 
# 1. Acesse https://www.mercadopago.com.br/developers/panel/credentials
# 2. Copie seu "Access Token"
# 3. Crie um arquivo .env na raiz do projeto
# 4. Cole seu token: MERCADO_PAGO_TOKEN=seu_access_token_aqui
# 5. Reinicie o servidor: node server.js
#
# Para modo SANDBOX (testes):
#   - Use o Access Token da seção "Credenciais de Teste"
#   - Crie uma conta de teste em https://www.mercadopago.com.br/developers/panel/accounts
#
# Para PRODUÇÃO:
#   - Use o Access Token da seção "Credenciais Produção"
#   - Teste com um cartão de crédito real
#
# Cartões de teste disponíveis em:
# https://www.mercadopago.com.br/developers/es/guides/resources/localization/accepted-cards
